{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@convex/_generated/*": ["./_generated/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
