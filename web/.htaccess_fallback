Options -MultiViews
RewriteEngine On
RewriteBase /

# ── 1. Always serve real files / dirs directly (e.g. favicon, robots.txt) ──
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── 2. Proxy _next/* static assets (JS, CSS, fonts, images, HMR) ────────────
#    These never exist as real files in public_html so they always need proxying
RewriteRule ^_next/(.*)$ index.php [QSA,L]

# ── 3. Proxy manifest, sitemap, robots generated by Next.js ─────────────────
RewriteRule ^(manifest\.webmanifest|sitemap\.xml|robots\.txt)$ index.php [QSA,L]

# ── 4. Proxy API routes ──────────────────────────────────────────────────────
RewriteRule ^api/(.*)$ index.php [QSA,L]

# ── 5. All other dynamic routes → Next.js ───────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
